{
  "manifest_version": 3,
  "name": "Web Performance Tester",
  "version": "1.0",
  "description": "测试网页性能指标，包括加载时间、FCP、TTI和自定义RTTI",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["more-metrics.html", "more-metrics.js"],
      "matches": ["<all_urls>"]
    }
  ]
}